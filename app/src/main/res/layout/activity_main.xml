<?xml version="1.0" encoding="utf-8"?>
<!-- Removed ScrollView to fix ListView visibility conflict -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1B2D"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/btn_star_big_on"
            app:tint="#2979FF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal Planner"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Goal Input Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginBottom="10dp">

        <EditText
            android:id="@+id/goalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:hint="Goal title..."
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8A9BB0"
            android:textSize="14sp" />

        <Button
            android:id="@+id/generateBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_primary_blue"
            android:text="Generate Plan"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Add Step Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginBottom="10dp">

        <EditText
            android:id="@+id/etStepInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:hint="Add a custom step..."
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8A9BB0"
            android:textSize="14sp" />

        <Button
            android:id="@+id/addStepBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_success_green"
            android:text="+ Add Step"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Progress Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Progress"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/percentageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#2979FF"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/customProgressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:progressDrawable="@drawable/custom_progress_bar" />

        <TextView
            android:id="@+id/motivationalText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:text="0 of 0 steps completed"
            android:textColor="#8A9BB0"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Steps Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Task List"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No steps yet. Start planning! 🚀"
        android:textColor="#8A9BB0"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:visibility="visible" />

    <!-- ListView - Height is now match_parent to fill remaining space -->
    <ListView
        android:id="@+id/stepsList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="#1E2D42"
        android:dividerHeight="1dp"
        android:listSelector="@android:color/transparent" />

</LinearLayout>
